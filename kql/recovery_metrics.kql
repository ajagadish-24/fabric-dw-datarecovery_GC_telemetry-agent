// Recovery Metrics – Restore, TimeTravel, TableClone, WarehouseClone, WarehouseRecovery
// Source: TridentBcdrReliability joined with Artifacts for customer names
TridentBcdrReliability
| where Timestamp >= ago(7d)
| where OperationName in ("Restore", "TimeTravelQuery", "TableClone", "TableClonePIT", "WarehouseClone", "WarehouseRecovery")
| join kind=leftouter (
    Artifacts
    | project WorkspaceId, CustomerName
) on WorkspaceId
| extend IsFailure = (ResultCode != 200)
| summarize
    TotalOperations = count(),
    Failures = countif(IsFailure),
    FailureRate = round(100.0 * countif(IsFailure) / count(), 2),
    P50LatencyMs = percentile(DurationMs, 50),
    P95LatencyMs = percentile(DurationMs, 95),
    P99LatencyMs = percentile(DurationMs, 99),
    UniqueCustomers = dcount(CustomerName),
    ImpactedCustomers = dcount(iff(IsFailure, CustomerName, ""))
  by bin(Timestamp, 1d), OperationName
| order by Timestamp desc, OperationName asc

